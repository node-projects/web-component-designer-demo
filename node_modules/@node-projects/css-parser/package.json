{
  "name": "@node-projects/css-parser",
  "version": "5.0.0",
  "description": "A modern CSS parser and stringifier with TypeScript support",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "docs/"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/benchmark": "^2.1.5",
    "@types/bytes": "^3.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "benchmark": "^2.1.4",
    "bytes": "^3.1.2",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "benchmark": "npm run build && node benchmark/index.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "clean": "rm -rf ./dist",
    "fix": "biome check --write",
    "lint": "biome check",
    "posttest": "npm run lint",
    "prebuild": "npm run clean",
    "build": "tsc",
    "bundle": "esbuild ./dist/index.js --format=esm --minify --sourcemap --platform=neutral --bundle --outfile=./dist/index-min.js",
    "postbuild": "npm run bundle"
  },
  "author": "TJ Holowaychuk <tj@vision-media.ca>",
  "contributors": [
    "Jochen Kühner <jochen.kuhner@gmx.de>",
    "Jean-Philippe Zolesio <holblin@gmail.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/node-projects/css-parser.git"
  },
  "keywords": [
    "css",
    "parser",
    "stringifier",
    "stylesheet",
    "ast",
    "typescript",
    "css-parser",
    "css-ast",
    "css-tools",
    "minify",
    "format",
    "preprocessor"
  ]
}
